# ===================
# Required
# ===================

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/c/cloud/api-keys
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/c/cloud/api-keys

# Database
DATABASE_URL=postgresql://whatis:whatis_dev@localhost:5432/whatis

# JWT: openssl rand -base64 24
JWT_SECRET=your-jwt-secret-here

# ===================
# Optional
# ===================

# PayPal - billing & credits (skipped when not configured)
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_MODE=sandbox # live / sandbox
PAYPAL_WEBHOOK_ID=xxx

# LLM - AI definitions (skipped when not configured, defaults: baseUrl=https://api.deepseek.com/v1, model=deepseek-chat)
LLM_API_KEY=xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# NATS - message streaming (skipped when not enabled)
NATS_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_TOKEN=

# Firebase - push notifications (skipped when not configured)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
